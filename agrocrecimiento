<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Agrocrecimiento · Sabiduría del Campo</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --v1: #0a2217; --v2: #1a3327; --v3: #275e44; --v4: #3b8a67; 
  --gold: #e9b741; --gold-light: #fad47a;
  --text-primary: #eae9e3; --text-secondary: #b0b5ae; --text-tertiary: #7a7f79;
  --bg-main: #0a2217; --bg-card: #1a3327; --bg-input: #0f2d1e;
  --shadow: 0 4px 20px rgba(0,0,0,0.6); --shadow-sm: 0 2px 8px rgba(0,0,0,0.4);
  --radius: 16px; --radius-lg: 24px;
  --font: 'Inter', sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{font-family:var(--font);background:var(--bg-main);color:var(--text-primary);min-height:100vh;font-size:15px;}

/* ----- SPLASH / AUTH ----- */
#splash{
  position:fixed;inset:0;z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:var(--bg-main);
  transition:opacity .5s;
  padding:20px;
}
#splash.oculta{opacity:0;pointer-events:none;}
.auth-card{
  width:100%;max-width:440px;
  background:rgba(26,51,39,0.85); backdrop-filter:blur(8px);
  border-radius:var(--radius-lg); padding:30px 28px 32px;
  box-shadow:var(--shadow);
  position:relative; overflow:hidden;
}
.auth-card::before{
  content:''; position:absolute; top:0; left:0; right:0; bottom:0;
  background:url('https://nuevarioja.com.ar/galeria/fotos/2026/01/23/l_1769217631.webp') no-repeat center/cover;
  opacity:0.15; z-index:0;
}
.auth-card > *{position:relative;z-index:1;}
.auth-brand{text-align:center;margin-bottom:20px;}
.auth-brand .green{color:var(--v4);font-weight:800;font-size:2rem;letter-spacing:-1px;}
.auth-brand .gold{color:var(--gold);font-weight:800;font-size:2rem;letter-spacing:-1px;}
.auth-brand .sub{font-size:0.85rem;color:var(--text-secondary);margin-top:4px;}
.auth-tabs{display:flex;background:var(--bg-input);border-radius:30px;padding:4px;margin-bottom:20px;}
.auth-tabs button{
  flex:1;border:none;padding:10px 0;border-radius:30px;font-weight:700;font-size:0.85rem;cursor:pointer;transition:.2s;
  background:transparent;color:var(--text-tertiary);font-family:var(--font);
}
.auth-tabs button.activo{background:var(--gold);color:var(--v1);box-shadow:0 2px 12px rgba(233,183,65,0.3);}
.auth-panel{display:none;flex-direction:column;gap:14px;}
.auth-panel.activo{display:flex;}
.fl{font-size:0.75rem;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:2px;display:block;}
.input-dark{
  width:100%;padding:12px 16px;border-radius:10px;border:1px solid var(--v2);
  background:var(--bg-input);color:var(--text-primary);font-family:var(--font);font-size:0.95rem;
  transition:.2s;
}
.input-dark:focus{outline:none;border-color:var(--gold);box-shadow:0 0 0 3px rgba(233,183,65,0.2);}
.btn-gold-full{
  width:100%;padding:14px;margin-top:4px;
  background:var(--gold);color:var(--v1);border:none;border-radius:30px;
  font-weight:800;font-size:1.05rem;cursor:pointer;transition:.2s;
  font-family:var(--font);letter-spacing:.3px;
}
.btn-gold-full:hover{transform:translateY(-2px);box-shadow:0 6px 24px rgba(233,183,65,0.5);}
.msg{font-size:0.8rem;padding:8px 12px;border-radius:8px;display:none;font-weight:500;}

/* ----- APP PRINCIPAL ----- */
#app{display:none;}#app.visible{display:block;}
.hdr{background:var(--v1);color:var(--text-primary);padding:14px 16px;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:100;border-bottom:1px solid var(--v2);}
.hdr-left{display:flex;align-items:center;gap:10px;}
.hdr-left h1{font-size:1.2rem;font-weight:800;}
.hdr-left span.gold{color:var(--gold);}
.hdr-right{display:flex;align-items:center;gap:8px;}
.btn-salir{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:var(--text-primary);padding:5px 14px;border-radius:20px;cursor:pointer;font-family:var(--font);font-size:.78rem;font-weight:600;}

.nav-bottom{position:fixed;bottom:0;left:0;right:0;background:var(--v1);border-top:1px solid var(--v2);display:flex;z-index:200;padding:6px 0 10px;}
.nav-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;color:var(--text-tertiary);transition:color .2s;gap:2px;}
.nav-item.activo{color:var(--gold);}
.nav-item i{font-size:1.3rem;}
.nav-item span{font-size:.6rem;font-weight:600;text-transform:uppercase;letter-spacing:.3px;}

.content{padding:16px 14px 90px;max-width:600px;margin:auto;}
.section{display:none;}.section.activo{display:block;}
.card{background:var(--bg-card);border-radius:var(--radius-lg);padding:20px;box-shadow:var(--shadow-sm);margin-bottom:16px;border:1px solid var(--v2);}
.card-title{font-size:1.1rem;font-weight:700;color:var(--gold);margin-bottom:14px;display:flex;align-items:center;gap:10px;}
.card-title i{font-size:.9rem;opacity:.8;}

/* ----- INICIO ----- */
.dash-hero{background:linear-gradient(135deg, var(--v1), var(--v3));border-radius:var(--radius-lg);padding:24px;margin-bottom:16px;color:var(--text-primary);position:relative;overflow:hidden;}
.dash-hero h2{font-size:1.3rem;font-weight:700;}
.dash-hero p{opacity:.85;font-size:.95rem;margin-top:4px;}
.mvv-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-top:12px;}
.mvv-item{background:var(--bg-input);padding:16px;border-radius:var(--radius);text-align:center;border:1px solid var(--v2);}
.mvv-item i{font-size:1.5rem;color:var(--gold);margin-bottom:6px;}
.mvv-item h4{font-size:.9rem;color:var(--gold);}
.mvv-item p{font-size:.8rem;color:var(--text-secondary);margin-top:4px;}

/* ----- RESEÑAS ----- */
.resena-item{background:var(--bg-card);border-radius:var(--radius);padding:16px;margin-bottom:14px;border-left:4px solid var(--gold);}
.resena-item h3{font-size:1.05rem;font-weight:700;color:var(--gold);}
.resena-item .meta{font-size:.8rem;color:var(--text-secondary);margin:4px 0;}
.resena-item p{font-size:.9rem;line-height:1.6;color:var(--text-primary);}

/* ----- CALCULADORA ----- */
.calc-campo{margin-bottom:12px;}
.calc-campo label{display:block;font-size:.75rem;font-weight:600;color:var(--text-secondary);margin-bottom:4px;text-transform:uppercase;letter-spacing:.4px;}
.input-app{width:100%;padding:12px 14px;border-radius:10px;border:1px solid var(--v2);background:var(--bg-input);color:var(--text-primary);font-family:var(--font);font-size:0.9rem;transition:.2s;}
.input-app:focus{outline:none;border-color:var(--gold);}
.resultado{background:var(--bg-input);padding:14px 16px;border-radius:14px;margin-top:12px;font-size:.9rem;line-height:1.8;border-left:4px solid var(--gold);}
.btn-group{display:flex;gap:10px;margin-top:12px;flex-wrap:wrap;}
.btn-whatsapp{flex:1;background:#25d366;color:#fff;border:none;padding:10px;border-radius:12px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;}
.btn-correo{flex:1;background:var(--v3);color:#fff;border:none;padding:10px;border-radius:12px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;}
.btn-main{width:100%;padding:12px;background:var(--gold);color:var(--v1);border:none;border-radius:12px;font-weight:700;cursor:pointer;font-size:.95rem;}

.glosario{background:var(--bg-input);border-radius:var(--radius);padding:16px;margin-top:12px;border:1px solid var(--v2);}
.glosario h4{color:var(--gold);margin-bottom:8px;}
.glosario .term{display:flex;gap:8px;margin-bottom:6px;font-size:.85rem;}
.glosario .term strong{color:var(--gold);min-width:70px;}

/* ----- CONSULTAS ----- */
.consulta-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.consulta-card{background:var(--bg-input);border-radius:var(--radius);padding:16px;text-align:center;cursor:pointer;transition:.2s;border:1px solid transparent;}
.consulta-card:hover{border-color:var(--gold);transform:translateY(-2px);}
.consulta-card h4{font-size:.9rem;color:var(--gold);margin-top:6px;}
.form-consulta{display:none;margin-top:12px;flex-direction:column;gap:10px;}
.form-consulta.activo{display:flex;}
.btn-responder{background:var(--gold);color:var(--v1);padding:12px;border:none;border-radius:10px;font-weight:700;cursor:pointer;}

/* ----- MAPA ----- */
#mapa{height:380px;border-radius:16px;margin-top:8px;border:1px solid var(--v2);}
.info-mapa{background:var(--bg-card);border-radius:12px;margin-top:12px;padding:0;overflow:hidden;border:1px solid var(--v2);}
.info-mapa-img{width:100%;height:180px;object-fit:cover;display:block;}
.info-mapa-body{padding:16px;}
.info-mapa-body h4{color:var(--gold);margin-bottom:4px;font-size:1.2rem;}
.info-mapa-body p{font-size:.85rem;line-height:1.6;color:var(--text-primary);}

/* ----- TIENDAS ----- */
.tienda-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:8px;}
.tienda-card{background:var(--bg-input);border-radius:var(--radius);padding:14px;border:1px solid var(--v2);text-align:center;transition:.2s;}
.tienda-card:hover{border-color:var(--gold);}
.tienda-card img{width:100%;height:120px;object-fit:cover;border-radius:10px;margin-bottom:8px;}
.tienda-card h4{font-size:.9rem;color:var(--gold);margin-bottom:4px;}
.tienda-card .reseña{font-size:.75rem;color:var(--text-secondary);margin:4px 0;}
.tienda-card .contacto{display:flex;justify-content:center;gap:12px;margin-top:6px;font-size:.85rem;}
.tienda-card .contacto a{color:var(--text-primary);transition:.2s;}
.tienda-card .contacto a:hover{color:var(--gold);}
.tienda-card .btn-tienda{display:inline-block;margin-top:6px;padding:4px 12px;background:var(--gold);color:var(--v1);border-radius:20px;text-decoration:none;font-size:.7rem;font-weight:700;}

/* ----- PERFIL ----- */
.perfil-avatar{width:80px;height:80px;border-radius:50%;background:var(--bg-input);display:flex;align-items:center;justify-content:center;font-size:3rem;margin:0 auto 12px;border:2px solid var(--gold);}
.perfil-info{text-align:center;margin-bottom:16px;}
.perfil-info h3{font-size:1.2rem;font-weight:700;color:var(--gold);}
.perfil-info p{font-size:.85rem;color:var(--text-secondary);}
.perfil-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--v2);font-size:.9rem;}
.perfil-row:last-child{border-bottom:none;}
.perfil-row i{color:var(--gold);width:20px;text-align:center;}

.toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:var(--gold);color:var(--v1);padding:12px 24px;border-radius:30px;z-index:9999;font-weight:700;font-size:.9rem;box-shadow:0 4px 20px rgba(233,183,65,0.4);animation:ta 4.2s forwards;}
@keyframes ta{0%{opacity:0;transform:translateX(-50%) translateY(20px)}10%{opacity:1;transform:translateX(-50%) translateY(0)}80%{opacity:1}100%{opacity:0;transform:translateX(-50%) translateY(-10px)}}
@media(min-width:500px){.content{padding:20px 20px 100px;}}
@media (max-width: 480px) {
  .tienda-grid { grid-template-columns: 1fr; }
  .mvv-grid { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<!-- ====== SPLASH / AUTH ====== -->
<div id="splash">
  <div class="auth-card">
    <div class="auth-brand">
      <div><span class="green">Agro</span><span class="gold">crecimiento</span></div>
      <div class="sub">La sabiduría del campo en tus manos</div>
    </div>
    <div class="auth-tabs">
      <button class="activo" id="tab-registro" onclick="cambiarPanelAuth('registro')">Crear cuenta</button>
      <button id="tab-login" onclick="cambiarPanelAuth('login')">Ya tengo cuenta</button>
    </div>
    <!-- REGISTRO -->
    <div class="auth-panel activo" id="panelRegistro">
      <div><span class="fl">Nombre completo</span><input type="text" id="regNombre" class="input-dark" placeholder="Juan Mamani"></div>
      <div><span class="fl">Teléfono / WhatsApp</span><input type="tel" id="regTelefono" class="input-dark" placeholder="7XXXXXXX"></div>
      <div><span class="fl">Correo electrónico</span><input type="email" id="regCorreo" class="input-dark" placeholder="juan@email.com"></div>
      <div><span class="fl">Zona / Departamento</span><input type="text" id="regZona" class="input-dark" placeholder="Santa Cruz, Montero..."></div>
      <button class="btn-gold-full" id="btnRegistro" onclick="handleRegistro()">Registrarme <i class="fas fa-arrow-right"></i></button>
      <div id="mensajeRegistro" class="msg"></div>
    </div>
    <!-- LOGIN -->
    <div class="auth-panel" id="panelLogin">
      <div><span class="fl">Correo electrónico</span><input type="email" id="loginCorreo" class="input-dark" placeholder="tu@correo.com"></div>
      <button class="btn-gold-full" id="btnLogin" onclick="handleLogin()">Iniciar sesión</button>
      <div id="mensajeLogin" class="msg"></div>
      <p style="text-align:center;font-size:0.8rem;color:var(--text-tertiary);margin-top:8px;">¿Sin cuenta? <a onclick="cambiarPanelAuth('registro')" style="color:var(--gold);cursor:pointer;">Crea una aquí</a></p>
    </div>
  </div>
</div>

<!-- ====== APP PRINCIPAL ====== -->
<div id="app">
  <div class="hdr">
    <div class="hdr-left"><div><h1>Agro<span class="gold">crecimiento</span></h1></div></div>
    <div class="hdr-right">
      <span id="hdrUser" style="font-size:.82rem;opacity:.85"></span>
      <button class="btn-salir" onclick="cerrarSesion()">Salir</button>
    </div>
  </div>

  <div class="content">

    <!-- ===== INICIO ===== -->
    <div class="section activo" id="s-inicio">
      <div class="dash-hero">
        <h2 id="saludo">¡Muy buenos días, productor!</h2>
        <p id="saludo-sub">Tu aliado digital para decisiones agrícolas inteligentes.</p>
      </div>
      <div class="card">
        <div class="card-title"><i class="fas fa-bullseye"></i> Objetivo, Misión y Visión</div>
        <div class="mvv-grid">
          <div class="mvv-item">
            <i class="fas fa-bullseye"></i>
            <h4>Objetivo</h4>
            <p>Empoderar a los productores bolivianos con herramientas digitales, datos agrícolas y acceso a servicios que optimicen su producción y rentabilidad.</p>
          </div>
          <div class="mvv-item">
            <i class="fas fa-flag"></i>
            <h4>Misión</h4>
            <p>Proveer información agrícola confiable, calcular inversiones, conectar con proveedores y facilitar la toma de decisiones basadas en datos reales.</p>
          </div>
          <div class="mvv-item">
            <i class="fas fa-eye"></i>
            <h4>Visión</h4>
            <p>Ser la plataforma agrícola líder de Bolivia, transformando el campo con tecnología y conocimiento al alcance de todos.</p>
          </div>
        </div>
      </div>
      <div class="card">
        <div class="card-title"><i class="fas fa-star"></i> ¿Qué puedes hacer hoy?</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:.85rem;color:var(--text-secondary);">
          <div>📖 <strong>Explorar reseñas de cultivos</strong><br><small>Conoce la historia y datos de cada producto</small></div>
          <div>🧮 <strong>Calcular tu inversión con glosario</strong><br><small>Aprende los términos financieros</small></div>
          <div>🗺️ <strong>Descubrir el mapa agrícola de Bolivia</strong><br><small>Ubica los cultivos en cada región</small></div>
          <div>🏪 <strong>Conocer proveedores y tiendas</strong><br><small>Encuentra insumos y servicios cerca de ti</small></div>
        </div>
      </div>
    </div>

    <!-- ===== RESEÑAS HISTÓRICAS ===== -->
    <div class="section" id="s-resenas">
      <div class="card">
        <div class="card-title"><i class="fas fa-book-open"></i> Reseña histórica de cultivos de Bolivia</div>
        <div id="resenaList"></div>
      </div>
    </div>

    <!-- ===== CALCULADORA ===== -->
    <div class="section" id="s-calc">
      <div class="card">
        <div class="card-title"><i class="fas fa-calculator"></i> Calculadora de inversión</div>
        <div class="calc-campo"><label>Cultivo</label><select id="calcCultivo" class="input-app" onchange="calcular()">
            <option value="soya">🌿 Soya</option><option value="maiz">🌽 Maíz</option><option value="cana">🪵 Caña</option>
            <option value="arroz">🍚 Arroz</option><option value="trigo">🌾 Trigo</option><option value="papa">🥔 Papa</option>
            <option value="cacao">🍫 Cacao</option><option value="cafe">☕ Café</option><option value="banano">🍌 Banano</option>
            <option value="quinua">🌾 Quinua</option>
        </select></div>
        <div class="calc-campo"><label>Hectáreas (1 ha = 10,000 m²)</label><input type="number" id="calcHa" class="input-app" value="1" min="0.1" step="0.5" oninput="calcular()"></div>
        <div class="calc-campo"><label>Capital disponible (Bs)</label><input type="number" id="calcCap" class="input-app" value="5000" min="0" oninput="calcular()"></div>
        <div id="calcResult" class="resultado">Selecciona un cultivo para ver el análisis detallado.</div>
        <div class="btn-group">
          <button class="btn-whatsapp" onclick="enviarWhatsApp()"><i class="fab fa-whatsapp"></i> Enviar a WhatsApp</button>
          <button class="btn-correo" onclick="enviarCorreo()"><i class="fas fa-envelope"></i> Enviar a Correo</button>
        </div>
        <button class="btn-main" onclick="guardarCalculo()" style="margin-top:10px;"><i class="fas fa-save"></i> Guardar en historial</button>
        
        <div class="glosario">
          <h4>📘 Glosario educativo</h4>
          <div class="term"><strong>Hectárea:</strong> Unidad de superficie agrícola. 1 hectárea equivale a 10,000 metros cuadrados (aprox. un campo de fútbol).</div>
          <div class="term"><strong>Rendimiento (t/ha):</strong> Es la cantidad de toneladas que se cosechan por cada hectárea sembrada. A mayor rendimiento, más producción.</div>
          <div class="term"><strong>Costo/Ha:</strong> Cuánto dinero se invierte en preparar la tierra, semillas, fertilizantes y labores por cada hectárea.</div>
          <div class="term"><strong>Precio/ton:</strong> Valor de venta de una tonelada del producto. Fluctúa según el mercado.</div>
          <div class="term"><strong>Ganancia:</strong> Lo que realmente se obtiene después de restar todos los costos de inversión. Ganancia = (Producción × Precio) - Costos.</div>
          <div class="term"><strong>ROI (%):</strong> Retorno sobre la inversión. Indica qué porcentaje de ganancia generó cada boliviano invertido. Ej: 50% significa que por cada 100 Bs invertidos, ganaste 50 Bs.</div>
        </div>
      </div>
      <!-- Comparador -->
      <div class="card">
        <div class="card-title"><i class="fas fa-balance-scale"></i> Comparar dos cultivos</div>
        <div style="display:flex;gap:8px;margin-bottom:10px;">
          <select id="compA" class="input-app" style="flex:1;" onchange="actualizarComp()">
            <option value="soya">Soya</option><option value="maiz">Maíz</option><option value="arroz">Arroz</option><option value="trigo">Trigo</option><option value="cana">Caña</option><option value="papa">Papa</option>
            <option value="cacao">Cacao</option><option value="cafe">Café</option><option value="banano">Banano</option><option value="quinua">Quinua</option>
          </select>
          <span style="align-self:center;font-weight:700;color:var(--gold)">vs</span>
          <select id="compB" class="input-app" style="flex:1;" onchange="actualizarComp()">
            <option value="maiz">Maíz</option><option value="soya">Soya</option><option value="arroz">Arroz</option><option value="trigo">Trigo</option><option value="cana">Caña</option><option value="papa">Papa</option>
            <option value="cacao">Cacao</option><option value="cafe">Café</option><option value="banano">Banano</option><option value="quinua">Quinua</option>
          </select>
        </div>
        <div class="comp-grid" id="compGrid" style="display:grid;grid-template-columns:1fr 1fr;gap:10px;"></div>
        <button class="btn-main" onclick="guardarComparacion()" style="margin-top:10px;"><i class="fas fa-save"></i> Guardar comparación en historial</button>
      </div>
    </div>

    <!-- ===== CONSULTAS (Formulario que envía a Sheets) ===== -->
    <div class="section" id="s-consulta">
      <div class="card">
        <div class="card-title"><i class="fas fa-headset"></i> Consulta técnica o asesoría</div>
        <div class="consulta-grid">
          <div class="consulta-card" onclick="mostrarFormulario('tecnica')">
            <i class="fas fa-microscope" style="font-size:2rem;color:var(--gold);"></i><h4>Consulta Técnica</h4>
          </div>
          <div class="consulta-card" onclick="mostrarFormulario('inversion')">
            <i class="fas fa-chart-pie" style="font-size:2rem;color:var(--gold);"></i><h4>Asesoría de Inversión</h4>
          </div>
        </div>
