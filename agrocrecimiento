// ===== CALCULADORA =====
function calcular() {
  var cult = document.getElementById('calcCultivo').value;
  var ha = parseFloat(document.getElementById('calcHa').value) || 0;
  var cap = parseFloat(document.getElementById('calcCap').value) || 0;
  if (ha <= 0) return;
  var d = CULTIVOS[cult];
  var precio = preciosActuales[cult] || d.precio;
  var prod = ha * d.rend;
  var inv = ha * d.costo;
  var gan = prod * precio - inv;
  var roi = inv > 0 ? (gan / inv * 100).toFixed(1) : 0;
  var col = gan >= 0 ? 'var(--gold)' : '#e74c3c';
  var capTxt = cap >= inv ? '✅ Capital suficiente. Sobran <strong>Bs ' + (cap - inv).toLocaleString('es-BO') + '</strong>' : '⚠️ Faltan <strong>Bs ' + (inv - cap).toLocaleString('es-BO') + '</strong>';
  document.getElementById('calcResult').innerHTML =
    '<strong style="font-size:1rem;color:var(--gold);">' + d.nombre + ' · ' + ha + ' ha</strong><br>' +
    '📦 Producción: <strong>' + prod.toFixed(1) + ' ton</strong><br>' +
    '💰 Inversión: <strong>Bs ' + inv.toLocaleString('es-BO') + '</strong><br>' +
    '📈 Ganancia: <strong style="color:' + col + ';">Bs ' + gan.toLocaleString('es-BO') + '</strong><br>' +
    '🔁 ROI: <strong style="color:' + col + ';">' + roi + '%</strong><br>' + capTxt;
}
window.calcular = calcular;

function guardarCalculo() {
  var cult = document.getElementById('calcCultivo').value;
  var ha = parseFloat(document.getElementById('calcHa').value) || 0;
  var d = CULTIVOS[cult];
  var gan = (ha * d.rend * preciosActuales[cult] - ha * d.costo).toFixed(0);
  var reg = { id: generarId(), fecha: new Date().toLocaleDateString('es-BO'), tipo: 'Simulación simple', cultivo: d.nombre, ha: ha, ganancia: parseInt(gan) };
  historial.unshift(reg);
  if (historial.length > 20) historial.pop();
  localStorage.setItem('agro_historial_' + usuario.correo, JSON.stringify(historial));
  toast('Simulación guardada.');
}

