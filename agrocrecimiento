// ===== MAPA DE BOLIVIA =====
function iniciarMapa() {
  if (mapaIniciado) return;
  mapaIniciado = true;
  mapaObj = L.map('mapa', { maxBounds: [[-22.9, -69.6], [-9.7, -57.5]] }).setView([-16.5, -64.5], 6);
  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', { attribution: '© OpenStreetMap' }).addTo(mapaObj);
  
  REGIONES_BOLIVIA.forEach(function(region) {
    var lat = region.coords[0];
    var lng = region.coords[1];
    
    var circulo = L.circle([lat, lng], { 
      radius: 80000, 
      color: 'rgba(255,255,255,0.6)', 
      fillColor: '#3b8a67', 
      fillOpacity: 0.25,
      weight: 2
    });
    circulo.addTo(mapaObj);
    
    region.productos.forEach(function(p) {
      var angulo = Math.random() * 2 * Math.PI;
      var offset = 0.5 + Math.random() * 1.2;
      var latP = lat + offset * Math.cos(angulo);
      var lngP = lng + offset * Math.sin(angulo);
      var color = coloresProductos[p] || '#ffffff';
      var d = CULTIVOS[p];
      
      var marcador = L.circleMarker([latP, lngP], {
        radius: 6,
        color: color,
        fillColor: color,
        fillOpacity: 0.8
      });
      marcador.addTo(mapaObj);
      marcador.bindPopup('<div style="color:#222;max-width:200px;"><b style="color:#e9b741;">' + d.emoji + ' ' + d.nombre + '</b><br>' + 
                         '<img src="' + d.img + '" style="width:100%;border-radius:8px;margin:4px 0;"><br>' +
                         '<small style="color:#444;">' + d.datos.substring(0, 80) + '...</small></div>');
    });
    
    circulo.on('click', function() {
      var html = '<div style="padding:0;">';
      var cultivosRegion = region.productos.map(function(p) { return CULTIVOS[p]; });
      
      if (cultivosRegion.length > 0) {
        html += '<img src="' + cultivosRegion[0].img + '" class="info-mapa-img" style="width:100%;height:180px;object-fit:cover;display:block;">';
      } else {
        html += '<div style="height:180px;background:var(--bg-input);display:flex;align-items:center;justify-content:center;color:var(--text-tertiary);">🌾 Cultivos variados</div>';
      }
      html += '<div class="info-mapa-body">';
      html += '<h4>' + region.nombre + '</h4>';
      html += '<p>' + region.descripcion + '</p>';
      html += '<div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;">';
      cultivosRegion.forEach(function(d) {
        html += '<span style="background:' + d.color + ';color:#fff;padding:4px 10px;border-radius:20px;font-size:.75rem;font-weight:700;">' + d.emoji + ' ' + d.nombre + '</span>';
      });
      html += '</div>';
      html += '<div style="margin-top:8px;font-size:.8rem;">';
      // Mostrar TODOS los productos de la región con explicación educativa
      cultivosRegion.forEach(function(d) {
        html += '<div style="padding:6px 0;border-bottom:1px solid var(--v2);">';
        html += '<strong>' + d.emoji + ' ' + d.nombre + ':</strong><br>';
        html += '<span style="display:inline-block;margin-top:2px;">🌡️ <strong>Clima ideal:</strong> ' + d.clima_explicacion + '</span><br>';
        html += '<span>📅 <strong>Época de siembra y cosecha:</strong> ' + d.campania_explicacion + '</span>';
        html += '</div>';
      });
      html += '</div></div></div>';
      
      document.getElementById('infoMapa').innerHTML = html;
      if (!document.getElementById('s-mapa').classList.contains('activo')) {
        navegar('mapa');
      }
    });
  });
  
  setTimeout(function(){ mapaObj.invalidateSize(); }, 500);
}

