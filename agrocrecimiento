function generarColores() {
  var coloresBase = ['#e74c3c', '#f1c40f', '#2ecc71', '#3498db', '#e67e22', '#9b59b6', '#1abc9c', '#d35400', '#aab7b8', '#f39c12'];
  var keys = Object.keys(CULTIVOS);
  keys.forEach(function(k, i) {
    coloresProductos[k] = CULTIVOS[k].color || coloresBase[i % coloresBase.length];
  });
}
generarColores();

// ===== UTILIDADES =====
function toast(msg) {
  var t = document.createElement('div'); t.className = 'toast'; t.innerHTML = '✅ ' + msg;
  document.body.appendChild(t); setTimeout(function(){t.remove();}, 4200);
}
function mostrarMsg(id, msg, tipo) {
  var el = document.getElementById(id); el.innerHTML = msg; el.style.display = 'block';
  el.style.background = tipo === 'error' ? '#4a1c1c' : '#1c4a2a';
  el.style.color = '#fff'; setTimeout(function(){el.style.display = 'none';}, 4000);
}
function generarId() { return Date.now(); }

// ===== AUTH =====
function cambiarPanelAuth(pestana) {
  var r = document.getElementById('panelRegistro');
  var l = document.getElementById('panelLogin');
  var tr = document.getElementById('tab-registro');
  var tl = document.getElementById('tab-login');
  if (pestana === 'registro') {
    r.classList.add('activo'); l.classList.remove('activo');
    tr.classList.add('activo'); tl.classList.remove('activo');
  } else {
    r.classList.remove('activo'); l.classList.add('activo');
    tr.classList.remove('activo'); tl.classList.add('activo');
  }
}
window.cambiarPanelAuth = cambiarPanelAuth;

function handleRegistro() {
  var nombre = document.getElementById('regNombre').value.trim();
  var tel = document.getElementById('regTelefono').value.trim();
  var correo = document.getElementById('regCorreo').value.trim().toLowerCase();
  var zona = document.getElementById('regZona').value.trim();
  if (!nombre || !tel || !correo || !zona) {
    mostrarMsg('mensajeRegistro', 'Todos los campos son obligatorios.', 'error');
    return;
  }
  var users = JSON.parse(localStorage.getItem('agro_users')) || [];
  if (users.find(function(u){ return u.correo === correo; })) {
    mostrarMsg('mensajeRegistro', 'Ese correo ya existe. Inicia sesión.', 'error');
    return;
  }
  var nuevo = { nombre: nombre, telefono: tel, correo: correo, zona: zona };
  users.push(nuevo);
  localStorage.setItem('agro_users', JSON.stringify(users));
  
  // Enviar a Google Sheets (Usuarios)
  enviarAGoogleSheets('registro', nuevo);
  
  iniciarSesion(nuevo);
}
window.handleRegistro = handleRegistro;

function handleLogin() {
  var correo = document.getElementById('loginCorreo').value.trim().toLowerCase();
  if (!correo) { mostrarMsg('mensajeLogin', 'Ingresa tu correo.', 'error'); return; }
  var users = JSON.parse(localStorage.getItem('agro_users')) || [];
  var encontrado = users.find(function(u){ return u.correo === correo; });
  if (encontrado) { iniciarSesion(encontrado); } 
  else { mostrarMsg('mensajeLogin', 'Correo no encontrado. Regístrate.', 'error'); }
}
window.handleLogin = handleLogin;

function iniciarSesion(user) {
  usuario = user;
  sessionStorage.setItem('usuario', JSON.stringify(user));
  document.getElementById('splash').classList.add('oculta');
  setTimeout(function(){ 
    document.getElementById('splash').style.display = 'none';
    document.getElementById('app').classList.add('visible');
    iniciarApp();
  }, 400);
}

function cerrarSesion() {
  sessionStorage.removeItem('usuario');
  document.getElementById('app').classList.remove('visible');
  var s = document.getElementById('splash'); s.style.display = 'flex'; s.classList.remove('oculta');
  document.getElementById('loginCorreo').value = '';
  cambiarPanelAuth('registro');
}
window.cerrarSesion = cerrarSesion;

// ===== NAVEGACIÓN =====
function navegar(sec) {
  document.querySelectorAll('.section').forEach(function(s){s.classList.remove('activo');});
  document.querySelectorAll('.nav-item').forEach(function(n){n.classList.remove('activo');});
  document.getElementById('s-' + sec).classList.add('activo');
  document.getElementById('nav-' + sec).classList.add('activo');
  window.scrollTo(0,0);
  
  if (sec === 'resenas') renderResenas();
  if (sec === 'calc') { calcular(); actualizarComp(); }
  if (sec === 'mapa') setTimeout(iniciarMapa, 300);
  if (sec === 'tiendas') renderTiendas();
  if (sec === 'perfil-usuario') renderPerfil();
  if (sec === 'consulta') { document.querySelectorAll('.form-consulta').forEach(function(f){f.classList.remove('activo');}); }
}
window.navegar = navegar;

// ===== INICIO APP =====
function iniciarApp() {
  var h = new Date().getHours();
  var sal = h < 12 ? '¡Muy buenos días, productor!' : h < 18 ? '¡Muy buenas tardes, productor!' : '¡Muy buenas noches, productor!';
  document.getElementById('saludo').textContent = sal;
  document.getElementById('hdrUser').textContent = usuario.nombre.split(' ')[0];
  cargarHistorial();
  renderResenas();
  renderPerfil();
  renderTiendas();
  calcular();
  actualizarComp();
  toast('Bienvenido, ' + usuario.nombre.split(' ')[0] + '!');
}

// ===== GOOGLE SHEETS INTEGRACIÓN =====
function enviarAGoogleSheets(tipo, datos) {
  fetch(GOOGLE_SCRIPT_URL, {
    method: 'POST',
    mode: 'no-cors',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ tipo: tipo, datos: datos })
  })
  .then(res => res.text())
  .then(text => {
    console.log('Enviado a Sheets:', text);
  })
  .catch(error => {
    console.error('Error al enviar a Sheets:', error);
  });
}

// ===== CONSULTAS (NUEVA LÓGICA) =====
function enviarConsulta(tipo) {
  var nombre, correo, detalle, titulo;
  if (tipo === 'Técnica') {
    nombre = document.getElementById('tecNombre').value.trim();
    correo = document.getElementById('tecCorreo').value.trim();
    detalle = document.getElementById('tecDetalle').value.trim() || 'Sin detalle';
    titulo = document.getElementById('tecTitulo').value.trim() || 'Consulta técnica general';
  } else {
    nombre = document.getElementById('invNombre').value.trim();
    correo = document.getElementById('invCorreo').value.trim();
    detalle = document.getElementById('invDetalle').value.trim() || 'Sin detalle';
    titulo = 'Inversión: ' + document.getElementById('invObjetivo').value;
  }
  
  if (!nombre || !correo) { toast('Por favor completa tu nombre y correo.'); return; }
  
  var solicitud = {
    id: 'SOL-' + Date.now(),
    fecha: new Date().toLocaleString('es-BO'),
    nombre: nombre,
    correo: correo,
    tipoSolicitud: tipo,
    detalle: detalle,
    titulo: titulo,
    estado: 'Pendiente'
  };
  
  // Enviar a Google Sheets (Solicitudes)
  enviarAGoogleSheets('solicitud', solicitud);
  
  // Notificar al usuario
  var mensaje = '✅ ¡Buenas ' + (new Date().getHours() < 12 ? 'días' : new Date().getHours() < 18 ? 'tardes' : 'noches') + ', ' + nombre + '!\n\n' +
                'Gracias por contactarte con Agrocrecimiento. Tu solicitud de **' + tipo + '** ha sido registrada con éxito.\n\n' +
                '📋 **Detalle de tu solicitud:**\n' + detalle + '\n\n' +
                '⏳ Estado: **Pendiente**. Nos comunicaremos contigo dentro de las **24 horas** hábiles.\n\n' +
                '🌱 Obtenemos los mejores cálculos para tu producción.';
  
  toast('✅ Consulta enviada. Recibirás respuesta en 24h.');
  alert(mensaje);
  
  // Limpiar formularios
  document.querySelectorAll('.form-consulta').forEach(function(f){f.classList.remove('activo');});
}
window.enviarConsulta = enviarConsulta;

