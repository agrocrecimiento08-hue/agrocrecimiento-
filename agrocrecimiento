// ===== COMPARADOR =====
function actualizarComp() {
  var ca = document.getElementById('compA').value;
  var cb = document.getElementById('compB').value;
  var da = CULTIVOS[ca], db = CULTIVOS[cb];
  function filas(d) {
    var gan = (1 * d.rend * preciosActuales[d.nombre.toLowerCase()] - 1 * d.costo).toFixed(0);
    return '<div style="display:flex;justify-content:space-between;"><span style="color:var(--text-secondary);">Rendimiento</span><span style="color:var(--gold);">' + d.rend + ' t/ha</span></div>' +
           '<div style="display:flex;justify-content:space-between;"><span style="color:var(--text-secondary);">Costo/ha</span><span style="color:var(--gold);">Bs ' + d.costo.toLocaleString('es-BO') + '</span></div>' +
           '<div style="display:flex;justify-content:space-between;"><span style="color:var(--text-secondary);">Ganancia/ha</span><span style="color:var(--gold);">Bs ' + parseInt(gan).toLocaleString('es-BO') + '</span></div>';
  }
  document.getElementById('compGrid').innerHTML =
    '<div style="background:var(--bg-input);border-radius:var(--radius);padding:12px;"><h4 style="color:var(--gold);">' + da.emoji + ' ' + da.nombre + '</h4>' + filas(da) + '</div>' +
    '<div style="background:var(--bg-input);border-radius:var(--radius);padding:12px;"><h4 style="color:var(--gold);">' + db.emoji + ' ' + db.nombre + '</h4>' + filas(db) + '</div>';
}
